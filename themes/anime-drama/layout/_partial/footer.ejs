<footer class="site-footer">
  <div class="footer-bg">
    <div class="footer-grid-pattern"></div>
  </div>
  
  <div class="container footer-content">
    <div class="footer-main">
      <div class="footer-section footer-about">
        <div class="footer-logo">
          <i class="fas fa-film"></i>
          <span><%= config.title %></span>
        </div>
        <p class="footer-description">
          专注漫剧创作，分享制作技巧与行业洞察
          <br>
          用创意和热情打造每一个精彩故事
        </p>
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Bilibili">
            <i class="fab fa-bilibili"></i>
          </a>
          <a href="#" class="social-link" aria-label="Weibo">
            <i class="fab fa-weibo"></i>
          </a>
          <a href="#" class="social-link" aria-label="Twitter">
            <i class="fab fa-twitter"></i>
          </a>
          <a href="#" class="social-link" aria-label="GitHub">
            <i class="fab fa-github"></i>
          </a>
          <a href="/atom.xml" class="social-link" aria-label="RSS">
            <i class="fas fa-rss"></i>
          </a>
        </div>
      </div>
      
      <div class="footer-section footer-links">
        <h4 class="footer-title">快速链接</h4>
        <ul class="footer-nav">
          <li><a href="/"><i class="fas fa-angle-right"></i> 首页</a></li>
          <li><a href="/archives"><i class="fas fa-angle-right"></i> 归档</a></li>
          <li><a href="/categories"><i class="fas fa-angle-right"></i> 分类</a></li>
          <li><a href="/tags"><i class="fas fa-angle-right"></i> 标签</a></li>
          <li><a href="/about"><i class="fas fa-angle-right"></i> 关于</a></li>
        </ul>
      </div>
      
      <div class="footer-section footer-categories">
        <h4 class="footer-title">分类目录</h4>
        <ul class="footer-nav">
          <% site.categories.forEach(function(category) { %>
          <li>
            <a href="<%= category.path %>">
              <i class="fas fa-folder-open"></i>
              <%= category.name %>
              <span class="count">(<%= category.length %>)</span>
            </a>
          </li>
          <% }) %>
        </ul>
      </div>
      
      <div class="footer-section footer-contact">
        <h4 class="footer-title">联系方式</h4>
        <ul class="contact-list">
          <li>
            <i class="fas fa-envelope"></i>
            <span>contact@example.com</span>
          </li>
          <li>
            <i class="fas fa-map-marker-alt"></i>
            <span>创意园区 · 数字媒体中心</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="copyright">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.title %>. All rights reserved.</p>
        <p>Powered by <a href="https://hexo.io/" target="_blank">Hexo</a> | Theme: Anime Drama</p>
      </div>
      <div class="footer-extra">
        <% if (config.beian) { %>
        <a href="https://beian.miit.gov.cn/" target="_blank"><%= config.beian %></a>
        <% } %>
      </div>
    </div>
  </div>
</footer>
