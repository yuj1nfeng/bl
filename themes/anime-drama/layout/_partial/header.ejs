<header class="site-header">
  <div class="header-bg-overlay"></div>
  
  <!-- Navigation -->
  <nav class="navbar">
    <div class="container navbar-container">
      <a href="/" class="navbar-brand">
        <span class="brand-icon">
          <i class="fas fa-film"></i>
        </span>
        <span class="brand-text"><%= config.title %></span>
      </a>
      
      <div class="navbar-menu" id="navbar-menu">
        <div class="navbar-links">
          <a href="/" class="nav-link <%= is_home() ? 'active' : '' %>">
            <i class="fas fa-home"></i>
            <span>首页</span>
          </a>
          <a href="/archives" class="nav-link <%= is_archive() ? 'active' : '' %>">
            <i class="fas fa-archive"></i>
            <span>归档</span>
          </a>
          <a href="/categories" class="nav-link <%= is_category() ? 'active' : '' %>">
            <i class="fas fa-folder"></i>
            <span>分类</span>
          </a>
          <a href="/tags" class="nav-link <%= is_tag() ? 'active' : '' %>">
            <i class="fas fa-tags"></i>
            <span>标签</span>
          </a>
          <a href="/about" class="nav-link">
            <i class="fas fa-user-astronaut"></i>
            <span>关于</span>
          </a>
        </div>
      </div>
      
      <div class="navbar-actions">
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <i class="fas fa-moon"></i>
        </button>
        <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
          <i class="fas fa-bars"></i>
        </button>
      </div>
    </div>
  </nav>
  
  <% if (is_home()) { %>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-particles" id="hero-particles"></div>
      <div class="hero-gradient"></div>
    </div>
    
    <div class="container hero-content">
      <div class="hero-badge">
        <i class="fas fa-sparkles"></i>
        <span>漫剧创作工作室</span>
      </div>
      
      <h1 class="hero-title">
        <span class="title-line">探索无限创意</span>
        <span class="title-line highlight">打造精品漫剧</span>
      </h1>
      
      <p class="hero-description">
        这里是漫剧制作的创意工坊，分享制作技巧、创作心得与行业动态
        <br>
        让我们一起创造触动人心的视觉故事
      </p>
      
      <div class="hero-actions">
        <a href="#latest-posts" class="btn btn-primary">
          <i class="fas fa-play"></i>
          <span>开始探索</span>
        </a>
        <a href="/about" class="btn btn-secondary">
          <i class="fas fa-info-circle"></i>
          <span>了解更多</span>
        </a>
      </div>
      
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-value" data-count="<%= site.posts.length %>">0</span>
          <span class="stat-label">作品</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">100+</span>
          <span class="stat-label">教程</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">10K+</span>
          <span class="stat-label">访客</span>
        </div>
      </div>
    </div>
    
    <div class="hero-scroll-indicator">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <span>向下滚动</span>
    </div>
  </section>
  <% } %>
</header>
