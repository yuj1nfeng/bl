<%- partial('_partial/header') %>

<div class="about-container">
  <div class="about-hero">
    <div class="about-avatar">
      <img src="/images/avatar.jpg" alt="Avatar" onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect fill=%22%237c3aed%22 width=%22100%22 height=%22100%22 rx=%2250%22/><text x=%2250%22 y=%2260%22 font-size=%2240%22 text-anchor=%22middle%22 fill=%22white%22>AD</text></svg>'">
    </div>
    <h1 class="about-title"><%= page.title %></h1>
    <p class="about-subtitle"><%= page.subtitle || '漫剧创作工作室' %></p>
  </div>
  
  <div class="about-content">
    <%- page.content %>
  </div>
  
  <div class="about-stats">
    <div class="about-stat-item">
      <i class="fas fa-film"></i>
      <span class="stat-number"><%= site.posts.length %></span>
      <span class="stat-label">作品数量</span>
    </div>
    <div class="about-stat-item">
      <i class="fas fa-book-open"></i>
      <span class="stat-number"><%= site.categories.length %></span>
      <span class="stat-label">分类</span>
    </div>
    <div class="about-stat-item">
      <i class="fas fa-tags"></i>
      <span class="stat-number"><%= site.tags.length %></span>
      <span class="stat-label">标签</span>
    </div>
    <div class="about-stat-item">
      <i class="fas fa-calendar"></i>
      <span class="stat-number"><%= new Date().getFullYear() - 2024 + 1 %></span>
      <span class="stat-label">年创作</span>
    </div>
  </div>
  
  <div class="about-skills">
    <h3 class="about-section-title">
      <i class="fas fa-magic"></i>
      创作技能
    </h3>
    <div class="skills-grid">
      <div class="skill-item">
        <div class="skill-icon">
          <i class="fas fa-pen-fancy"></i>
        </div>
        <h4>剧本创作</h4>
        <p>故事构思、角色塑造、对白设计</p>
      </div>
      <div class="skill-item">
        <div class="skill-icon">
          <i class="fas fa-palette"></i>
        </div>
        <h4>美术设计</h4>
        <p>角色设计、场景绘制、色彩搭配</p>
      </div>
      <div class="skill-item">
        <div class="skill-icon">
          <i class="fas fa-video"></i>
        </div>
        <h4>动画制作</h4>
        <p>分镜设计、动作捕捉、后期特效</p>
      </div>
      <div class="skill-item">
        <div class="skill-icon">
          <i class="fas fa-music"></i>
        </div>
        <h4>音效配乐</h4>
        <p>背景音乐、音效设计、配音指导</p>
      </div>
    </div>
  </div>
  
  <div class="about-contact">
    <h3 class="about-section-title">
      <i class="fas fa-envelope"></i>
      联系我们
    </h3>
    <p>如果您有任何合作意向或问题，欢迎通过以下方式联系我们：</p>
    <div class="contact-methods">
      <a href="mailto:contact@example.com" class="contact-method">
        <i class="fas fa-envelope"></i>
        <span>contact@example.com</span>
      </a>
      <a href="#" class="contact-method">
        <i class="fab fa-weixin"></i>
        <span>微信公众号</span>
      </a>
      <a href="#" class="contact-method">
        <i class="fab fa-bilibili"></i>
        <span>哔哩哔哩</span>
      </a>
    </div>
  </div>
</div>


<style>
.about-container {
  max-width: 900px;
  margin: 0 auto;
  padding: var(--spacing-3xl) var(--spacing-lg);
}

.about-hero {
  text-align: center;
  margin-bottom: var(--spacing-3xl);
}

.about-avatar {
  width: 150px;
  height: 150px;
  margin: 0 auto var(--spacing-xl);
  border-radius: 50%;
  overflow: hidden;
  border: 4px solid var(--color-accent-primary);
  box-shadow: var(--shadow-glow);
}

.about-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.about-title {
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 800;
  margin-bottom: var(--spacing-sm);
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.about-subtitle {
  color: var(--color-text-secondary);
  font-size: 1.2rem;
}

.about-content {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  margin-bottom: var(--spacing-2xl);
  border: 1px solid var(--color-border);
  line-height: 1.9;
  color: var(--color-text-secondary);
}

.about-content h1, .about-content h2, .about-content h3 {
  color: var(--color-text-primary);
  margin-top: var(--spacing-xl);
  margin-bottom: var(--spacing-md);
}

.about-content p {
  margin-bottom: var(--spacing-lg);
}

.about-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-3xl);
}

.about-stat-item {
  text-align: center;
  padding: var(--spacing-xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  transition: all var(--transition-base);
}

.about-stat-item:hover {
  border-color: var(--color-accent-primary);
  transform: translateY(-5px);
}

.about-stat-item i {
  font-size: 2rem;
  color: var(--color-accent-secondary);
  margin-bottom: var(--spacing-md);
}

.stat-number {
  display: block;
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-label {
  display: block;
  color: var(--color-text-muted);
  font-size: 0.9rem;
  margin-top: var(--spacing-xs);
}

.about-section-title {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xl);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.about-section-title i {
  color: var(--color-accent-secondary);
}

.about-skills {
  margin-bottom: var(--spacing-3xl);
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--spacing-lg);
}

.skill-item {
  text-align: center;
  padding: var(--spacing-xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  transition: all var(--transition-base);
}

.skill-item:hover {
  border-color: var(--color-accent-primary);
  transform: translateY(-5px);
}

.skill-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-primary);
  border-radius: var(--radius-lg);
  font-size: 1.5rem;
  color: white;
}

.skill-item h4 {
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.skill-item p {
  color: var(--color-text-muted);
  font-size: 0.9rem;
}

.about-contact {
  text-align: center;
}

.contact-methods {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--spacing-md);
  margin-top: var(--spacing-xl);
}

.contact-method {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
  transition: all var(--transition-base);
}

.contact-method:hover {
  border-color: var(--color-accent-primary);
  color: var(--color-text-primary);
  transform: translateY(-3px);
}

.contact-method i {
  color: var(--color-accent-secondary);
}
</style>
